# Environment Configuration for AgriDrone Research Prototype

# Logging
LOG_LEVEL=INFO
LOG_FILE=outputs/logs/agridrone.log

# Data Paths
DATA_DIR=data
OUTPUTS_DIR=outputs
CONFIG_DIR=configs

# Model Configuration
MODEL_NAME=yolov8n-seg
MODEL_PATH=models/yolov8n-seg.pt
DEVICE=cuda

# Safety Flags - MUST be explicitly set for real actuation
DRY_RUN=true
SAFE_TEST_FLUID_ONLY=true

# Inference
INFERENCE_CONFIDENCE=0.5
INFERENCE_IOU=0.45
BATCH_SIZE=8

# API
API_HOST=0.0.0.0
API_PORT=8000
API_DEBUG=false

# Geospatial
CRS_EPSG=32633  # Example: WGS84 UTM Zone 33N
GRID_CELL_SIZE_M=10

# Prescription
PRESCRIPTION_SEVERITY_THRESHOLD=0.6
PRESCRIPTION_SPRAY_RATE_HIGH=1.0
PRESCRIPTION_SPRAY_RATE_MEDIUM=0.5
PRESCRIPTION_SPRAY_RATE_LOW=0.2

# Environmental Fusion
ENV_TEMP_MIN=5.0
ENV_TEMP_MAX=35.0
ENV_HUMIDITY_MIN=30.0
ENV_HUMIDITY_MAX=90.0

# Actuation
PUMP_PIN=17
VALVE_PIN=27
PUMP_DEFAULT_RATE=0.5

# Simulation
SIM_FIELD_WIDTH_M=100
SIM_FIELD_HEIGHT_M=100
SIM_HOTSPOT_DENSITY=0.15
SIM_RANDOM_SEED=42

# Research Metadata
RESEARCH_TEAM=AgriDrone
RESEARCH_VERSION=0.1.0
